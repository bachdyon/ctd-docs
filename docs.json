{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ContentTuDong",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Tài liệu",
        "groups": [
          {
            "group": "Trang chủ",
            "pages": ["index"]
          },
          {
            "group": "Bắt đầu nhanh",
            "pages": [
              "bat-dau-nhanh/README",
              "bat-dau-nhanh/bien-moi-truong"
            ]
          },
          {
            "group": "Hướng dẫn sử dụng",
            "pages": [
              "huong-dan-su-dung/README",
              "huong-dan-su-dung/dang-nhap-va-phan-quyen",
              "huong-dan-su-dung/chat-va-session",
              "huong-dan-su-dung/video-va-tai-nguyen"
            ]
          },
          {
            "group": "Hướng dẫn đóng góp",
            "pages": ["huong-dan-dong-gop/README"]
          },
          {
            "group": "Liên hệ / Hỗ trợ",
            "pages": ["lien-he-ho-tro"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/bachdyon/vtd",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Hỗ trợ",
        "href": "/lien-he-ho-tro"
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bachdyon/vtd"
    }
  }
}
